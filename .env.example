# ──────────────────────────────────────────────
# Stockdrop Environment Variables
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────

# Email Configuration
# SMTP Server (e.g., smtp.gmail.com for Gmail)
SMTP_SERVER=
SMTP_PORT=

# Sender Account (Use an App Password for Gmail)
SENDER_EMAIL=
SENDER_PASSWORD=

# Recipient Email (Where you want to receive alerts)
RECIPIENT_EMAIL=

# Google Gemini (primary AI model)
GEMINI_API_KEY=

# Google Cloud Storage
GOOGLE_STORAGE_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

# Alpaca (broker API)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Finnhub (market data)
FINNHUB_API_KEY=

# Alpha Vantage (market data)
ALPHA_VANTAGE_API_KEY=

# FRED (Federal Reserve economic data)
FRED_API_KEY=

# Polygon (market data)
POLYGON_API_KEY=

# Benzinga (news + market data)
BENZINGA_API_KEY=

# Seeking Alpha via RapidAPI
RAPIDAPI_KEY_SEEKING_ALPHA=

# News Digest integration
# Root of the news archive tree (FT Archive/, Finimize Archive/, Portfolio_Total_Weights.xlsx live inside)
NEWS_ARCHIVE_ROOT=
# Gemini model used to generate digests
NEWS_DIGEST_MODEL=gemini-3.1-pro-preview
# Reasoning depth for digest calls (low | high)
NEWS_DIGEST_THINKING_LEVEL=high
# Turn digest generation on/off without code changes
NEWS_DIGEST_ENABLED=true
